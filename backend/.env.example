# ─── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database ─────────────────────────────────────────────────
# If the MongoDB password contains special characters like @ # $ % : / ? & =
# encode the password before using it in MONGO_URI.
# Example: my@pass#123 => my%40pass%23123
MONGO_URI=mongodb+srv://<user>:<encodedPassword>@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# ─── Authentication ────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
OTP_EXPIRES_IN_MINUTES=10

# ─── CORS ─────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ─── Email / SMTP ─────────────────────────────────────────────
# Optional in Render deployments. If these are missing, the backend still starts.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM="Auth App <your_email@gmail.com>"

# ─── Cloud Storage ────────────────────────────────────────────

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
